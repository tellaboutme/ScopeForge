NEXT_PUBLIC_API_URL=http://localhost:8000
DATABASE_URL=postgresql+psycopg://scopeforge:scopeforge@localhost:5435/scopeforge
AI_PROVIDER=groq
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=replace_me
AI_MODEL=openai/gpt-oss-120b
ANALYSIS_MOCK_MODE=true
# Phase 9 (D037) — leave false for local dev (plain http://localhost).
# Set true only behind real HTTPS in production, or the session cookie will
# be silently dropped by the browser (Secure cookies require https).
SESSION_COOKIE_SECURE=false

# D042 security hardening — all optional, all off/blank by default so local
# dev and the test suite never need real credentials to run.
#
# Cloudflare Turnstile CAPTCHA on register/login (free, unlimited —
# https://dash.cloudflare.com/?to=/:account/turnstile). Leave
# TURNSTILE_ENABLED=false to skip entirely.
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
# The site key is public and belongs on the frontend, not here — see
# apps/web/.env.local's NEXT_PUBLIC_TURNSTILE_SITE_KEY.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Outbound email (verification links) via Resend's REST API — 3,000 free
# emails/month, no card required (https://resend.com/api-keys). Leave
# RESEND_API_KEY blank to skip sending; accounts still work unverified
# (verification is non-blocking by design).
RESEND_API_KEY=
# Resend's shared sandbox sender works with no domain setup, but can only
# deliver to the email on the Resend account itself until a custom domain
# is verified there — swap this once that's done.
EMAIL_FROM_ADDRESS=ScopeForge <onboarding@resend.dev>
# Where the deployed frontend actually lives. Two jobs, one setting: builds
# the links in verification/reset emails (${APP_BASE_URL}/verify-email?
# token=...) AND is added to the API's CORS allowlist alongside the two
# hardcoded localhost origins (apps/api/app/main.py) so the real frontend's
# requests aren't rejected. Change this for any non-localhost deployment —
# e.g. on Render, set it to your frontend service's actual URL.
APP_BASE_URL=http://localhost:3000
